<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<!-- App Configuration -->
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Divya Jyotish</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>a_one_ios_app</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<!-- iOS Version Support -->
		<key>MinimumOSVersion</key>
		<string>13.0</string>
		<!-- Device Capabilities -->
		<key>UIDeviceFamily</key>
		<array>
			<integer>1</integer>
			<!-- iPhone -->
			<integer>2</integer>
			<!-- iPad -->
		</array>
		<!-- Status Bar Configuration -->
		<key>UIStatusBarStyle</key>
		<string>UIStatusBarStyleDefault</string>
		<key>UIViewControllerBasedStatusBarAppearance</key>
		<false/>
		<!-- Launch Screen -->
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<!-- Supported Interface Orientations (iPhone) -->
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<!-- Supported Interface Orientations (iPad) -->
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<!-- App Transport Security (ATS) -->
		<!-- Production-ready: Allow only specific domains -->
		<key>NSAppTransportSecurity</key>
		<dict>
			<key>NSExceptionDomains</key>
			<dict>
				<!-- Allow bishnuprasadchundali.com.np with HTTPS -->
				<key>bishnuprasadchundali.com.np</key>
				<dict>
					<key>NSIncludesSubdomains</key>
					<true/>
					<key>NSExceptionAllowsInsecureHTTPLoads</key>
					<false/>
					<key>NSExceptionRequiresForwardSecrecy</key>
					<true/>
					<key>NSExceptionMinimumTLSVersion</key>
					<string>TLSv1.2</string>
				</dict>
			</dict>
		</dict>
		<!-- Internet Usage Description -->
		<key>NSInternetUsageDescription</key>
		<string>This app requires internet access to display web content.</string>
		<!-- Camera Access (if needed for WebView file upload) -->
		<key>NSCameraUsageDescription</key>
		<string>This app needs access to your camera to upload photos.</string>
		<!-- Photo Library Access (if needed for WebView file upload) -->
		<key>NSPhotoLibraryUsageDescription</key>
		<string>This app needs access to your photo library to upload photos.</string>
		<!-- Microphone Access (if needed for WebView audio recording) -->
		<key>NSMicrophoneUsageDescription</key>
		<string>This app needs access to your microphone for audio recording.</string>
		<!-- Location Access (if needed) -->
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>This app needs access to your location.</string>
		<!-- Flutter Configuration -->
		<key>io.flutter.embedded_views_preview</key>
		<true/>
		<!-- Background Modes (if needed) -->
		<!--
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	-->
		<key>UIStatusBarHidden</key>
		<true/>
	</dict>
</plist>
